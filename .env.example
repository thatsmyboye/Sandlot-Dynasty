# Database (PostgreSQL on Railway)
DATABASE_URL="postgresql://user:password@host:5432/sandlot_dynasty"

# App
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Cron security — any long random string; set same value in Railway cron header
CRON_SECRET="your-cron-secret-here"

# Node env
NODE_ENV="development"
