{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/api/health",
    "cronJobs": [
      {
        "schedule": "0 15 * * *",
        "command": "curl -s -X POST https://$RAILWAY_PUBLIC_DOMAIN/api/cron/simulate -H 'Authorization: Bearer $CRON_SECRET'"
      },
      {
        "schedule": "0 18 * * *",
        "command": "curl -s -X POST https://$RAILWAY_PUBLIC_DOMAIN/api/cron/simulate -H 'Authorization: Bearer $CRON_SECRET'"
      },
      {
        "schedule": "0 21 * * *",
        "command": "curl -s -X POST https://$RAILWAY_PUBLIC_DOMAIN/api/cron/simulate -H 'Authorization: Bearer $CRON_SECRET'"
      },
      {
        "schedule": "0 0 * * *",
        "command": "curl -s -X POST https://$RAILWAY_PUBLIC_DOMAIN/api/cron/simulate -H 'Authorization: Bearer $CRON_SECRET'"
      }
    ]
  }
}
